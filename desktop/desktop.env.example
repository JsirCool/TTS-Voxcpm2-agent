# Copy this file to .desktop/desktop.env and edit the paths for your machine.
# Or open desktop/launcher.py and save from the UI.

API_PORT=8100
WEB_PORT=3010

# Desktop runtime data root (logs, sqlite db, local object storage)
HARNESS_DESKTOP_ROOT=.desktop-runtime

# Local reference / clone audio root
HARNESS_VOICE_SOURCE_DIR=..\voice_sourse

# VoxCPM model directory
VOXCPM_MODEL_PATH=E:\VC\pretrained_models\VoxCPM2

# WhisperX / Hugging Face cache root
HF_HOME=E:\VC\hf-cache
