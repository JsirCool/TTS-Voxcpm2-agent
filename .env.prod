# =============================================================================
# TTS Agent Harness — Prod 环境配置模板
#
# 用法: cp .env.prod .env && 编辑填入真实 secret
# ${...} 标记的变量必须替换为真实值。
# =============================================================================

# === Infrastructure ===
POSTGRES_PORT=5432
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
PREFECT_PORT=4200

# === Database ===
DATABASE_URL=postgresql+asyncpg://harness:${DB_PASSWORD}@postgres:5432/harness

# === MinIO ===
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=${MINIO_KEY}
MINIO_SECRET_KEY=${MINIO_SECRET}
MINIO_BUCKET=tts-harness
MINIO_SECURE=false

# === Prefect ===
PREFECT_API_URL=http://prefect-server:4200/api

# === Application Ports ===
API_PORT=8000
WEB_PORT=3010

# === WhisperX ===
WHISPERX_URL=http://whisperx-svc:7860
WHISPERX_MODE=docker

# === Next.js ===
NEXT_PUBLIC_API_URL=/api

# === Fish TTS API ===
FISH_TTS_KEY=${FISH_KEY}
# FISH_TTS_REFERENCE_ID=
# FISH_TTS_MODEL=s2-pro

# === 运行模式 ===
TTS_USE_PREFECT=1
HARNESS_API_TOKEN=${API_TOKEN}
LOG_LEVEL=warning

# === 网络/代理 ===
# 生产环境一般不需要代理
# HTTPS_PROXY=
# NO_PROXY=
