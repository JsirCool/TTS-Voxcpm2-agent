# =============================================================================
# TTS Agent Harness - local VoxCPM + WhisperX development config
# Usage: copy this file to .env and adjust paths / ports as needed.
# =============================================================================

# === Infrastructure ===
POSTGRES_PORT=55432
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
PREFECT_PORT=54200

# === Database ===
DATABASE_URL=postgresql+asyncpg://harness:harness@localhost:55432/harness

# === MinIO ===
MINIO_ENDPOINT=localhost:59000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tts-harness
MINIO_SECURE=false

# === Prefect ===
PREFECT_API_URL=http://localhost:54200/api

# === Application Ports ===
API_PORT=8100
WEB_PORT=3010

# === Local WhisperX ===
WHISPERX_URL=http://127.0.0.1:7860
WHISPERX_MODE=local

# === Local VoxCPM ===
VOXCPM_URL=http://127.0.0.1:8877
VOXCPM_MODEL_PATH=E:\VC\pretrained_models\VoxCPM2
VOXCPM_DEVICE=cuda:0
VOXCPM_OPTIMIZE=1
VOXCPM_ENABLE_DENOISER=0
VOXCPM_CFG_VALUE=2.0
VOXCPM_INFERENCE_TIMESTEPS=10
# VOXCPM_REFERENCE_AUDIO_PATH=
# VOXCPM_PROMPT_AUDIO_PATH=
# VOXCPM_PROMPT_TEXT=
# VOXCPM_CONTROL_PROMPT=

# === Next.js ===
NEXT_PUBLIC_API_URL=http://localhost:8100

# === Storage management ===
STORAGE_QUOTA_GB=5
STORAGE_TARGET_GB=4

# === Runtime mode ===
# TTS_USE_PREFECT=
# HARNESS_API_TOKEN=
LOG_LEVEL=info

# === Network / proxy ===
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1
