# =============================================================================
# TTS Agent Harness — Test 环境配置
#
# 用法: cp .env.test .env
# 同 dev，但 FISH_TTS_KEY 可选（不设则跳过真实 P2 测试）
# =============================================================================

# === Infrastructure ===
POSTGRES_PORT=55432
MINIO_API_PORT=59000
MINIO_CONSOLE_PORT=59001
PREFECT_PORT=54200

# === Database ===
DATABASE_URL=postgresql+asyncpg://harness:harness@localhost:55432/harness

# === MinIO ===
MINIO_ENDPOINT=localhost:59000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tts-harness
MINIO_SECURE=false

# === Application ===
API_PORT=8100
WEB_PORT=3010
WHISPERX_URL=http://localhost:7860
WHISPERX_MODE=local
NEXT_PUBLIC_API_URL=http://localhost:8100
LOG_LEVEL=info

# === Fish TTS (可选 — 不设则 P2 真实测试跳过) ===
# FISH_TTS_KEY=

# === 运行模式 ===
# TTS_USE_PREFECT=
# HARNESS_API_TOKEN=

# === 网络 ===
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
NO_PROXY=localhost,127.0.0.1
